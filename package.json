{
  "name": "alphamindplus-site",
  "version": "1.0.0",
  "private": true,
  "devDependencies": {
    "http-server": "^14.1.1",
    "html-validator-cli": "^6.0.0",
    "pa11y": "^6.0.0",
    "linkinator": "^3.0.1",
    "esbuild": "^0.19.0",
    "clean-css-cli": "^5.3.2",
    "svgo": "^3.0.0"
  },
  "scripts": {
    "start": "http-server ./ -p 8080",
    "build:js": "esbuild assets/js/main.js assets/js/jobs.js --bundle --minify --sourcemap --outdir=assets/dist --format=esm",
    "build:css": "cleancss -o assets/dist/styles.min.css assets/css/styles.css",
    "build:svg": "svgo assets/images/favicon.svg -o assets/dist/favicon.svg",
    "build": "mkdir -p assets/dist && npm run build:js && npm run build:css && npm run build:svg",
    "audit:html": "html-validator --file index.html --verbose",
    "audit:pa11y": "pa11y http://localhost:8080",
    "audit:links": "linkinator http://localhost:8080 -r --skipExternal"
  }
}
